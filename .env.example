# Session cookie signing secret — set a long random value in production.
SESSION_SECRET=

# When set, real SMS sending is assumed and the dev notices/simulator disappear.
TELNYX_API_KEY=
TELNYX_FROM_NUMBER=
TELNYX_MESSAGING_PROFILE_ID=
# Portal → Account → Public Key; enables webhook signature verification.
TELNYX_PUBLIC_KEY=

# Protects /api/cron/digests; Vercel cron sends it automatically when set.
CRON_SECRET=

# Comma-separated 10-digit phone numbers whose accounts get the /admin portal.
ADMIN_PHONES=

# Where new-ad review notifications are emailed (needs RESEND_API_KEY). Optional.
ADMIN_EMAIL=

# When set, real Stripe checkout replaces the dev payment simulation.
STRIPE_SECRET_KEY=
# Signing secret for the Stripe webhook endpoint (/api/stripe/webhook).
STRIPE_WEBHOOK_SECRET=

# When set, real email sending is assumed and the dev email viewer disappears.
RESEND_API_KEY=
EMAIL_FROM="The Plain Exchange <ads@theplainexchange.com>"
# Signing secret (whsec_…) for the Resend Inbound webhook (/api/email/inbound),
# which subscribes anyone who emails subscribe@theplainexchange.com. Required in
# production for that route to accept requests (fails closed without it).
RESEND_WEBHOOK_SECRET=
# The inbound address people email to subscribe. Defaults to the value below.
EMAIL_INBOUND_ADDRESS=subscribe@theplainexchange.com

# Absolute base URL used in email links and images (production: the real domain).
SITE_URL=

# When both are set, the app switches from local fixtures to Supabase.
# See supabase/README.md for setup. The service-role key is a server-only secret.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
