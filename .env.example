# Session cookie signing secret — set a long random value in production.
SESSION_SECRET=

# When set, real SMS sending is assumed and the dev notices/simulator disappear.
TELNYX_API_KEY=
TELNYX_FROM_NUMBER=
TELNYX_MESSAGING_PROFILE_ID=
# Portal → Account → Public Key; enables webhook signature verification.
TELNYX_PUBLIC_KEY=

# Protects /api/cron/digests; Vercel cron sends it automatically when set.
CRON_SECRET=

# Comma-separated 10-digit phone numbers whose accounts get the /admin portal.
ADMIN_PHONES=

# When set, real email sending is assumed and the dev email viewer disappears.
RESEND_API_KEY=
EMAIL_FROM="The Plain Exchange <ads@theplainexchange.com>"

# Absolute base URL used in email links and images (production: the real domain).
SITE_URL=

# When both are set, the app switches from local fixtures to Supabase.
# See supabase/README.md for setup. The service-role key is a server-only secret.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
