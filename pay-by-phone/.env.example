# ---- Twilio ----
# Console > Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# The unique name you gave the Stripe Pay Connector when you installed it.
# If you installed it as the default, leave this as "Default".
TWILIO_PAY_CONNECTOR=Default
# Optional: a Twilio number to text the "card saved" confirmation from.
# Leave blank to skip SMS confirmations.
TWILIO_SMS_FROM=

# ---- Stripe ----
# Secret key from the SAME Stripe account you connected to the Pay Connector.
# Use sk_test_... while the connector is in test mode, sk_live_... in production.
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_STRIPE_SECRET_KEY

# ---- App ----
PORT=3000
# Long random string; required as "Authorization: Bearer <key>" on POST /charge
INTERNAL_API_KEY=change-me-to-a-long-random-string
BUSINESS_NAME=The Plain Exchange
# Set to "production" to enforce Twilio webhook signature validation
NODE_ENV=development
